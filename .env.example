# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- LLM (orchestrator + judges) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORCHESTRATOR_MODEL=gpt-4o-mini
OPENAI_CRAG_MODEL=gpt-4o-mini
USE_LLM_PLANNER=false
USE_LLM_STEP_BACK=false
ANTHROPIC_API_KEY=

# --- Neo4j (LightRAG backend) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme

# --- LightRAG working dir ---
LIGHTRAG_WORKING_DIR=./rag_storage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage

# --- BM25 (Elasticsearch example; Whoosh uses local path) ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=docs_bm25

# --- Redis cache ---
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS_QUERY_CACHE=true
LIGHTRAG_QUERY_CACHE_TTL_SEC=300

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=

# --- Web search (CRAG fallback) ---
SERPAPI_API_KEY=
# TAVILY_API_KEY=
